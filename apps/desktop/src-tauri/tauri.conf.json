{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shardseed",
  "version": "0.1.0",
  "identifier": "org.shardseed.prototype",
  "build": {
    "beforeDevCommand": "npm run desktop:frontend:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run desktop:frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shardseed",
        "width": 1120,
        "height": 760
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
